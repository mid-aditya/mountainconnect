{
  "title": "MountainConnect ID - API Overview",
  "uid": "mountainconnect-overview",
  "version": 1,
  "tags": ["mountainconnect", "api", "production"],
  "timezone": "browser",
  "schemaVersion": 38,
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "API Latency - P50/P95/P99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "P50" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "P95" },
        { "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "P99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 2}] } } }
    },
    {
      "id": 2,
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "targets": [{ "expr": "rate(http_requests_total[5m])", "legendFormat": "req/s" }]
    },
    {
      "id": 3,
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "targets": [{ "expr": "rate(http_requests_total{status=~\"5..\"}[5m]) / rate(http_requests_total[5m]) * 100", "legendFormat": "Error %" }],
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 5}] } } }
    },
    {
      "id": 4,
      "title": "Active Users (Real-time)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 8 },
      "targets": [{ "expr": "active_users", "legendFormat": "Active Users" }]
    },
    {
      "id": 5,
      "title": "Active SOS Events",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 8 },
      "targets": [{ "expr": "sos_active_count", "legendFormat": "SOS Active" }],
      "fieldConfig": { "defaults": { "unit": "none", "min": 0, "max": 50, "thresholds": { "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 5}, {"color": "red", "value": 15}] } } }
    },
    {
      "id": 6,
      "title": "WebSocket Connections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 8 },
      "targets": [{ "expr": "ws_connections_total", "legendFormat": "WS Connections" }]
    },
    {
      "id": 7,
      "title": "WebSocket Connections Over Time",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [{ "expr": "rate(ws_connections_total[5m])", "legendFormat": "WS/sec" }]
    },
    {
      "id": 8,
      "title": "Queue Depth",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "targets": [
        { "expr": "bullmq_waiting_count{queue=\"sos-emergency\"}", "legendFormat": "SOS Queue" },
        { "expr": "bullmq_waiting_count{queue=\"email-notifications\"}", "legendFormat": "Email Queue" },
        { "expr": "bullmq_waiting_count{queue=\"weather-alerts\"}", "legendFormat": "Weather Queue" }
      ]
    },
    {
      "id": 9,
      "title": "DB Connection Pool",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "targets": [{ "expr": "pg_stat_activity_count{datname=\"mountainconnect\"}", "legendFormat": "DB Connections" }]
    },
    {
      "id": 10,
      "title": "CPU Usage per Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 4, "x": 16, "y": 12 },
      "targets": [
        { "expr": "rate(process_cpu_seconds_total{job=\"mountainconnect-api\"}[5m])", "legendFormat": "API" },
        { "expr": "rate(process_cpu_seconds_total{job=\"mountainconnect-worker\"}[5m])", "legendFormat": "Worker" }
      ]
    },
    {
      "id": 11,
      "title": "Memory Usage per Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 4, "x": 20, "y": 12 },
      "targets": [
        { "expr": "process_resident_memory_bytes{job=\"mountainconnect-api\"}", "legendFormat": "API" },
        { "expr": "process_resident_memory_bytes{job=\"mountainconnect-worker\"}", "legendFormat": "Worker" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    }
  ],
  "refresh": "30s",
  "editable": true,
  "style": "dark"
}
